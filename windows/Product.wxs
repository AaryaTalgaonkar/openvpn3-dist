<?xml version="1.0" encoding="UTF-8"?>


<Wix
    xmlns="http://wixtoolset.org/schemas/v4/wxs"
    xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
    xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package
    Name="IITDelhiVPN"
    Version="1.0.0"
    Manufacturer="IITDelhi"
    UpgradeCode="949A75F8-69B4-4981-B2FA-60695CEED6FE"
    Scope="perMachine">

    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />

    <Icon Id="AppIcon" SourceFile="logo.ico"/>
    <Property Id="ARPPRODUCTICON" Value="AppIcon"/>

    <MediaTemplate EmbedCab="yes"/>

    <!-- ===================================================== -->
    <!-- DIRECTORIES -->
    <!-- ===================================================== -->
    <StandardDirectory Id="ProgramFiles64Folder">

      <Directory Id="INSTALLDIR" Name="IITDelhiVPN">
        <Directory Id="OPENVPNDIR" Name="openvpn3"/>
        <Directory Id="GUIDIR" Name="gui"/>
        <Directory Id="DRIVERDIR" Name="drivers">
          <Directory Id="TAPDIR" Name="tap-win"/>
        </Directory>


      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppProgramsFolder" Name="IITDelhiVPN"/>
    </StandardDirectory>

    <!-- ===================================================== -->
    <!-- REGISTRY COMPONENT -->
    <!-- ===================================================== -->
    <Component
      Id="RegistryEntries"
      Guid="82fdf3eb-e307-4cc8-af33-23ce3b5e7518">

      <RegistryKey Root="HKLM" Key="SOFTWARE\OpenVPN">
        <RegistryValue
          Name="omi_exe_path"
          Type="string"
          Value=""
          KeyPath="yes"/>
      </RegistryKey>

    </Component>

    <!-- ===================================================== -->
    <!-- TAP DRIVER FILES -->
    <!-- ===================================================== -->
    <ComponentGroup Id="TapFiles" Directory="TAPDIR">

      <Component Id="TapComponent"
                 Guid="f9926af4-e88e-404b-a942-94c48a9fe27f">

        <File Id="TapInstallExe"
              Source="tap-driver\tapinstall.exe"
              KeyPath="yes"/>

        <File Source="tap-driver\OemVista.inf"/>
        <File Source="tap-driver\tap0901.sys"/>
        <File Source="tap-driver\tap0901.cat"/>

      </Component>
    </ComponentGroup>

    <ComponentGroup Id="TapScripts" Directory="TAPDIR">
      <Component Id="RemoveTapScriptComponent" Guid="c9926af4-e88e-404b-a942-94c48a9fe27f">
        <File Id="RemoveTapScriptFile"
              Source="remove-tap.ps1"
              KeyPath="yes"/>
      </Component>
    </ComponentGroup>


    <!-- ===================================================== -->
    <!-- OPENVPN AGENT + SERVICE -->
    <!-- ===================================================== -->
    <ComponentGroup Id="OpenVPNFiles" Directory="OPENVPNDIR">

      <Component Id="OvpnAgentComponent"
                 Guid="fd34089c-da4d-4eb5-ac82-3f4778b28ab4">

        <File Id="OvpnAgentExe"
              Source="openvpn3\ovpnagent.exe"
              KeyPath="yes"/>

        <File Source="openvpn3\omicliagent.exe"/>

        <!-- SERVICE INSTALL -->
        <ServiceInstall
          Id="OvpnAgentServiceInstall"
          Name="ovpnagent"
          DisplayName="OpenVPN Agent"
          Description="OpenVPN 3 Agent Service"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"/>

        <!-- SERVICE CONTROL -->
        <ServiceControl
          Id="OvpnAgentServiceControl"
          Name="ovpnagent"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes"/>

      </Component>
        <Files Include="openvpn3\*.dll" />
    </ComponentGroup>

    <!-- ===================================================== -->
    <!-- CUSTOM ACTIONS -->
    <!-- ===================================================== -->


    <!-- 1. Install TAP Driver Setup (Uses SetProperty to safely format paths) -->
    <SetProperty 
      Id="InstallTap_CmdLine" 
      Value="&quot;[TAPDIR]tapinstall.exe&quot; install &quot;[TAPDIR]OemVista.inf&quot; tap0901" 
      Before="InstallTap" />
      
    <CustomAction
      Id="InstallTap"
      BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
      DllEntry="WixQuietExec"
      Execute="deferred"
      Impersonate="no"
      Return="check"/>

    <!-- 2. Remove TAP Driver via Exe -->
    <CustomAction
      Id="RemoveTap"
      FileRef="TapInstallExe"
      ExeCommand="remove tap0901"
      Execute="deferred"
      Impersonate="no"
      Return="ignore"/>
    
    <!-- 3. Remove TAP Driver Store via PowerShell (Uses SetProperty to safely format paths) -->
    <SetProperty 
      Id="RemoveTapDriverStore_CmdLine" 
      Value="&quot;[SystemFolder]windowspowershell\v1.0\powershell.exe&quot; -ExecutionPolicy Bypass -WindowStyle Hidden -File &quot;[TAPDIR]remove-tap.ps1&quot;" 
      Before="RemoveTapDriverStore" />

    <CustomAction
      Id="RemoveTapDriverStore"
      BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
      DllEntry="WixQuietExec"
      Execute="deferred"
      Impersonate="no"
      Return="ignore"/>


    <!-- ===================================================== -->
    <!-- EXECUTION SEQUENCE -->
    <!-- ===================================================== -->
    <InstallExecuteSequence>



      <!-- Runs during installation after files hit the disk -->
      <Custom
        Action="InstallTap"
        After="InstallFiles"
        Condition="NOT Installed"/>

      <!-- Runs during uninstall while files still exist on disk -->
      <Custom
        Action="RemoveTap"
        Before="RemoveTapDriverStore"
        Condition="REMOVE=&quot;ALL&quot;"/>
      
      <Custom
        Action="RemoveTapDriverStore"
        Before="RemoveFiles"
        Condition="REMOVE=&quot;ALL&quot;"/>





    </InstallExecuteSequence>

    <!-- ===================================================== -->
    <!-- FEATURE -->
    <!-- ===================================================== -->
    <Feature Id="MainFeature"
             Title="IIT Delhi VPN"
             Level="1">

      <ComponentRef Id="RegistryEntries"/>
      <ComponentGroupRef Id="TapFiles"/>
      <ComponentGroupRef Id="TapScripts"/>
      <ComponentGroupRef Id="OpenVPNFiles"/>
      <ComponentGroupRef Id="GuiExeGroup"/>
      <ComponentGroupRef Id="GuiAllOtherFiles"/>
    </Feature>

  </Package>
</Wix>
